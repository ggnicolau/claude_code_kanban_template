{
  "enableAllProjectMcpServers": true,
  "alwaysThinkingEnabled": false,
  "cleanupPeriodDays": 7,
  "feedbackSurveyRate": 0,
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Agent(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(jupyter *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(diff *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(aws *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(conda *)",
      "Bash(Rscript *)",
      "Bash(pandoc *)",
      "Bash(which *)",
      "Bash(export *)",
      "Bash(touch *)",
      "mcp__github__get_file_contents",
      "mcp__github__get_me",
      "mcp__github__search_repositories",
      "mcp__github__list_branches",
      "mcp__github__list_issues",
      "mcp__github__issue_read",
      "mcp__github__issue_write",
      "mcp__github__pull_request_read",
      "mcp__github__pull_request_review_write",
      "mcp__github__create_pull_request",
      "mcp__github__update_pull_request",
      "mcp__github__merge_pull_request",
      "mcp__github__add_issue_comment",
      "mcp__github__add_reply_to_pull_request_comment",
      "mcp__github__create_branch",
      "mcp__github__update_pull_request_branch",
      "mcp__github__sub_issue_write",
      "mcp__github__list_commits",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__search_users",
      "mcp__github__get_commit",
      "mcp__github__get_label",
      "PowerShell(Get-Command *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Test-Path *)"
    ],
    "ask": [
      "mcp__github__fork_repository",
      "mcp__github__create_repository"
    ],
    "deny": [
      "mcp__github__delete_file",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git branch -D dev)",
      "Bash(git branch -D main)",
      "Bash(git push --delete origin dev)",
      "Bash(git push --delete origin main)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(gh repo delete*)",
      "Bash(gh release delete*)",
      "Bash(gh secret set*)",
      "Bash(gh secret delete*)",
      "Bash(gh variable set*)",
      "Bash(gh auth login*)",
      "Bash(gh auth token*)",
      "Bash(gh ssh-key add*)",
      "PowerShell(Remove-Item *)",
      "PowerShell(git push --force*)",
      "PowerShell(git reset --hard*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/session_start.sh\"",
            "statusMessage": "Carregando estado do projeto..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/post_write.sh\"",
            "statusMessage": "Atualizando arquivos..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  }
}
